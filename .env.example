# Materials Project API Key (required)
# Register for a free API key at: https://next-gen.materialsproject.org/
MP_API_KEY=your_materials_project_api_key_here

# Groq API Key (optional) — powers the LLM layer of the auto-discovery
# monitor: paper relevance filtering, claim extraction, champion verdicts.
# Free key at: https://console.groq.com  (pipeline runs fine without it)
GROQ_API_KEY=your_groq_api_key_here
# Optional model override (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.1-8b-instant

# Optional webhook (Slack/Discord) for new-champion alerts
# NOTIFY_WEBHOOK=https://hooks.slack.com/services/...
